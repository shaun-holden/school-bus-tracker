# App Store Connect API key — TEMPLATE ONLY. Copy real values into your shell
# environment in a PLAIN terminal; never commit real values or the .p8 file.
#
# Generate the key: App Store Connect > Users and Access > Integrations >
# App Store Connect API > (+) generate a key with "App Manager" access.
# Download the AuthKey_XXXXXXXXXX.p8 ONCE and store it OUTSIDE this repo.
#
# Then, in a plain terminal (not a Claude pane):
#   export ASC_KEY_ID=...
#   export ASC_ISSUER_ID=...
#   export ASC_KEY_FILEPATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
#   fastlane ios beta

ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_FILEPATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
