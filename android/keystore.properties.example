# Android release signing — TEMPLATE ONLY.
# Copy this to android/keystore.properties (that path is gitignored) and fill in
# real values. The passwords never enter a Claude pane — you type them yourself.
#
# 1. Create the upload keystore ONCE (choose your own passwords when prompted):
#      keytool -genkeypair -v \
#        -keystore ~/keys/school-bus-tracker-upload.jks \
#        -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# 2. BACK UP that .jks file and the passwords somewhere safe (a password manager).
#    If you lose them you can never publish an update to this app on Google Play.
#
# 3. Point storeFile at wherever you saved the .jks (keep it OUTSIDE the repo).

storeFile=/Users/deshaunholden/keys/school-bus-tracker-upload.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
