{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Coach 🧭",
      "detail": "Claude window you talk to in plain English; drafts prompts for Dev/Shell",
      "type": "shell",
      "command": "claude",
      "runOptions": { "runOn": "folderOpen" },
      "presentation": {
        "group": "dashboard",
        "panel": "dedicated",
        "reveal": "always",
        "focus": false,
        "echo": false,
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "Dev 🔨",
      "detail": "Claude window that writes app code (drives react-builder / express-api)",
      "type": "shell",
      "command": "claude",
      "runOptions": { "runOn": "folderOpen" },
      "presentation": {
        "group": "dashboard",
        "panel": "dedicated",
        "reveal": "always",
        "focus": false,
        "echo": false,
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "Shell 🐚",
      "detail": "Claude window for ops/tests/review/git (never writes app code)",
      "type": "shell",
      "command": "claude",
      "runOptions": { "runOn": "folderOpen" },
      "presentation": {
        "group": "dashboard",
        "panel": "dedicated",
        "reveal": "always",
        "focus": false,
        "echo": false,
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "🚀 dev",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "runOptions": { "runOn": "folderOpen" },
      "presentation": {
        "group": "dashboard",
        "panel": "dedicated",
        "reveal": "always",
        "focus": false,
        "echo": false
      },
      "problemMatcher": []
    },
    {
      "label": "🌐 open site",
      "detail": "Waits for the dev server on :5001, then opens it in the default browser",
      "type": "shell",
      "command": "for i in $(seq 1 120); do curl -sf -o /dev/null http://localhost:5001 && break; sleep 0.5; done; open http://localhost:5001",
      "runOptions": { "runOn": "folderOpen" },
      "presentation": {
        "group": "dashboard",
        "panel": "shared",
        "reveal": "silent",
        "focus": false,
        "echo": false,
        "showReuseMessage": false,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "🟢 Open Dashboard (Coach + Dev + Shell + dev)",
      "dependsOn": ["Coach 🧭", "Dev 🔨", "Shell 🐚", "🚀 dev", "🌐 open site"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
